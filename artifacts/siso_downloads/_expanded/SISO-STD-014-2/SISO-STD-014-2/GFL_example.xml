<?xml version="1.0" encoding="UTF-8"?> 
<gfl:gfl xmlns:srml="http://sisostds.org/schemas/srml" xmlns:gfl="http://www.sisostds.org/schemas/gfl" 
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="schemas/gfl/GFL.xsd"> 
 
 <!-- Basic GFL file demonstrating the use of the geoFilter, classFilter, and relativeGeoFilter filters --> 
 
 <!-- This example filters data from one simulation to another using a bounding sphere and limiting the rate at which matching data is forwarded. -->
 <gfl:filter id="geoExample"> 
  <!-- This filter applies to data from "SimulationX" and filters data going to "SimulationY" --> 
  <gfl:appliesTo> 
   <gfl:fromSide>SimulationX</gfl:fromSide> 
   <gfl:toSide>SimulationY</gfl:toSide> 
  </gfl:appliesTo> 
  <!-- The filter statement --> 
  <gfl:filterStatement> 
   <!-- A geofilter specified as a spherical volume-->
   <gfl:geoFilter> 
    <gfl:boundingSphere lengthUnits="meters"> <!-- radius units are meters --> 
     <!-- The center of the sphere in the simulation coordinate system -->
	 <gfl:center> 
      <gfl:X>23.45</gfl:X> 
      <gfl:Y>101.23</gfl:Y> 
      <gfl:Z>30.11</gfl:Z> 
     </gfl:center> 
     <!-- The radius of the sphere --> 
     <gfl:radius>500</gfl:radius> 
    </gfl:boundingSphere> 
   </gfl:geoFilter> 
  </gfl:filterStatement> 
  <!-- The action to take if the filter condition is met--> 
  <gfl:action> 
   <!-- Forward data... --> 
   <gfl:forward> 
    <!-- At a rate of 100 messages/second --> 
    <gfl:rate> 
     <gfl:value>100</gfl:value> 
     <gfl:timeUnits>seconds</gfl:timeUnits> 
    </gfl:rate> 
   </gfl:forward> 
  </gfl:action> 
 </gfl:filter> 
 
 <!-- This example filter demonstrates the use of class-attribute filtering stopping data from one simulation from going to two others if the specified attribute values are seen.--> 
 <gfl:filter id="classAttributeExample"> 
  <!-- This filter applies to data from "SimulationY" and filters data going to "SimulationZ" and "SimulationX" --> 
  <gfl:appliesTo> 
   <gfl:fromSide>SimulationY</gfl:fromSide> 
   <gfl:toSide>SimulationZ,SimulationX</gfl:toSide> 
  </gfl:appliesTo> 
  <!-- Use a class-attribute filter on class "Platform" and attribute "Type" --> 
  <gfl:filterStatement> 
   <gfl:classFilter> 
    <gfl:classIdentifier>Platform</gfl:classIdentifier> 
    <gfl:attribute> 
     <gfl:name>Type</gfl:name> 
     <!-- Filter on enumerated values "Car" and "Truck" for the "Type" attribute --> 
     <gfl:enumeratedValue> 
      <gfl:enumeration>Car</gfl:enumeration> 
      <gfl:enumeration>Truck</gfl:enumeration> 
     </gfl:enumeratedValue> 
    </gfl:attribute> 
   </gfl:classFilter> 
  </gfl:filterStatement> 
  <!-- Drop data meeting this filter rule --> 
  <gfl:action> 
   <gfl:stop/> 
  </gfl:action> 
 </gfl:filter> 
 
 <!-- This example filter demonstrates filtering on a relative spatial volume centered on a simulation entity, forwarding all data from one simulation to another if it is generated by entities or events within a cyclindrical volume around the sprecified entity. --> 
 <gfl:filter id="relativeGeoExample"> 
  <!-- This filter applies to data from "SimulationX" and filters data going to "SimulationZ" --> 
  <gfl:appliesTo> 
   <gfl:fromSide>SimulationX</gfl:fromSide> 
   <gfl:toSide>SimulationZ</gfl:toSide> 
  </gfl:appliesTo> 
  <gfl:filterStatement> 
   <!-- Filter on a simulation entity named "SimObjectInstance" --> 
   <gfl:relativeGeoFilter> 
    <gfl:instanceIdentifier>SimObjectInstance</gfl:instanceIdentifier> 
    <!-- Filter data around the entity in an enclosing cylinder --> 
    <gfl:enclosingVolume lengthUnits="meters"> 
     <gfl:cylinder> 
      <!-- Use a radius of 50 meters with the entity at the center --> 
      <gfl:radius>50</gfl:radius> 
      <!-- Use a height of 30 meters, split evenly on the entity (15 above, 15 below) --> 
      <gfl:height>30</gfl:height> 
     </gfl:cylinder> 
    </gfl:enclosingVolume> 
   </gfl:relativeGeoFilter> 
  </gfl:filterStatement> 
  <gfl:action> 
   <!-- Simply forward at the rate received--> 
   <gfl:forward/> 
  </gfl:action> 
 </gfl:filter> 
</gfl:gfl> 
