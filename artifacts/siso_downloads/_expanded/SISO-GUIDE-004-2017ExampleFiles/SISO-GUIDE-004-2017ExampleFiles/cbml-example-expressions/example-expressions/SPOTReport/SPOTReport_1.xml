			<CredibilityCode>RPTFCT</CredibilityCode>
			<ReliabilityCode>A</ReliabilityCode>
		</ReportingData>
		<Who>
			<ObjectItem xsi:type="OtherMateriel">
				<OID>1026: Vehicle</OID>
