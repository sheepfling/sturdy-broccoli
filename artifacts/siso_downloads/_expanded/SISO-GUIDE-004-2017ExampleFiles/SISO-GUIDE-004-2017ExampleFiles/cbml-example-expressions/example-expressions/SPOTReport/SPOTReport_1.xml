				<OID>1026: Vehicle</OID>
			</ObjectItemRef>
		</WhoRef>
			<!-- saLute: Location -->
			<Location xsi:type="GeographicPoint">
				<OID>1028</OID>			
				<LatitudeCoordinate>60.3</LatitudeCoordinate>
				<LongitudeCoordinate>80.2</LongitudeCoordinate>
			</Location>
			<ObjectItemLocation>
				<OID>0</OID>
				<!-- sAlute: Activities of the enemy (if moving, always give direction of movement) -->
				<BearingAngle>12</BearingAngle>
				<SpeedRate>70</SpeedRate>
				<MeaningCode>ADRPRP</MeaningCode>
			</ObjectItemLocation>
	</Report>
