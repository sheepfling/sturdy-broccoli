			</ObjectItem>
		</Who>
		<ObjectTypeRef xsi:type="VehicleTypeRef">
			<OID>1025: Truck 4x4</OID>
		</ObjectTypeRef>
	</Report>
	<Report xsi:type="WhoStatusType">
