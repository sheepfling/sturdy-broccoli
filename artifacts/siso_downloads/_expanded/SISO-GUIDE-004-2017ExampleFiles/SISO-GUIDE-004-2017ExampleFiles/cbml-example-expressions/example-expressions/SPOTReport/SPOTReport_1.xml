<Report>
	<Context xsi:type="OtherContext">
		<OID>0</OID>
		<NameText>SPOT Report C-BML Example</NameText>
		<ContextCategoryCode>NOS</ContextCategoryCode>
	</Context>
	<!-- SPOT Report using the mnemonic “SALUTE” -->
