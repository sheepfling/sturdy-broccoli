			<OID>1049</OID>
			<ReportingDataCategoryCode>REP</ReportingDataCategoryCode>
			<CredibilityCode>RPTFCT</CredibilityCode>
			<ReliabilityCode>A</ReliabilityCode>
		</ReportingData>
		<Event>
			<Where>
				<SpecificLocation>
					<LocationRef xsi:type="GeographicPointRef">
						<OID>1028</OID>			
					</LocationRef>
				</SpecificLocation>
			</Where>
			<Resource xsi:type="ActionResourceItem">
				<ActionResourceQualifierCode>AUTH</ActionResourceQualifierCode>
				<!-- salutE: Equipment carried by the enemy, including their weapons -->
				<ObjectItemRef xsi:type="OtherMaterielRef">
					<OID>1026: Vehicle</OID>
				</ObjectItemRef>
			</Resource>
			<EventWhat>
				<ActionEvent xsi:type="OtherActionEvent">
					<OID>0</OID>
					<NameText>Vehicle 1026 is Moving.</NameText>
					<!-- sAlute: Activities of the enemy (if moving, always give direction of movement) -->
					<ActionEventCategoryCode>MOVING</ActionEventCategoryCode>
				</ActionEvent>
			</EventWhat>
		</Event>
	</Report>
