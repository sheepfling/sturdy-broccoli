			<ObjectItemRef xsi:type="OtherMaterielRef">
				<OID>1026: Vehicle</OID>
			</ObjectItemRef>
		</WhoRef>
		<AbstractObjectItemStatus xsi:type="OtherMaterielStatus">
			<OperationalStatusCode>OPR</OperationalStatusCode>
		</AbstractObjectItemStatus>
	</Report>
	<Report xsi:type="WhoHoldingType">
		<ReporterWho>
			<OrganisationRef xsi:type="UnitRef">
				<OID>0003: UAV Platoon</OID>
