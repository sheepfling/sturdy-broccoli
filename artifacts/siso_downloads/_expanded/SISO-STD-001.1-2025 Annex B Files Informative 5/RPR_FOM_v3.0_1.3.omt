    (Class (ID 87)
        (Name "ModeSTransponder")
        (PSCapabilities PS)
        (Description "IFF/SSR transponder Mode S capability.")
        (SuperClass 85)
        (Attribute (Name "AircraftAddress")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "A unique ICAO Mode S Aircraft Address. When a military aircraft has both a permanent and an operational Mode S Aircraft Address, only one address will be active at a time. The active aircraft address shall be included in this attribute.")
        )
        (Attribute (Name "AircraftIdentificationType")
            (DataType "AircraftIdentificationTypeEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "The aircraft identification type.")
        )
        (Attribute (Name "AircraftIdentification")
            (DataType "ASCIIcharArray8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "The International Civil Aviation Organization (ICAO) flight identity of the aircraft, either the flight ID (i.e., call sign) or the registration number (also referred to as the tail number) of the aircraft. This attribute shall consist of an eight-element American Standard Code for Information Interchange (ASCII) character string consisting of the letters A to Z and the numbers 0 to 9. An aircraft identification may be less than eight characters. This string shall begin with the left-most character located at the lowest index. Unused characters shall be indicated by Null (0) values.")
        )
        (Attribute (Name "SquitterIsOn")
            (DataType "RPRboolean")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates whether the squitter is On (1) or Off (0).")
        )
        (Attribute (Name "SquitterType")
            (DataType "ModeSSquitterTypeEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates the type of Mode S squitter.")
        )
        (Attribute (Name "CapabilityReport")
            (DataType "CapabilityReportEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "The Mode S Transponder Capability Report. The numeric values are from Annex 10 to ICAO Vol. IV, para 3.1.2.5.2.2.1, except for No Statement. If no specific capability is indicated, this field shall be set to No Statement (255).")
        )
        (Attribute (Name "AircraftPresentDomain")
            (DataType "AircraftPresentDomainEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates the present domain of the aircraft. Surface means on a water platform surface such as a ship deck or on the water surface directly (e.g., pontoon-equipped aircraft). This field is referred to as Flight Status in ICAO Publications.")
        )
        (Attribute (Name "AltitudeAvailable")
            (DataType "RPRboolean")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates whether the actual Mode S altitude is available in the attribute Altitude or is to be derived from entity truth data.")
        )
        (Attribute (Name "Altitude")
            (DataType "TransponderRelativeAltitudeVariantStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "The actual Mode S altitude as determined by the Mode S transponder model, represented as a binary coded altitude referenced to -1000 feet. All altitudes greater than 50 175 feet shall be reported with 100-foot resolution. A receiving simulation is not required to process an actual Mode S altitude value by this standard and may always compute it from the entity truth altitude.")
        )
        (Attribute (Name "SquitterRecordSource")
