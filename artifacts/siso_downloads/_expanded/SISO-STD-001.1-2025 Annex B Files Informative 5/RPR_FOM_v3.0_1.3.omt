        )
        (ComplexComponent (FieldName "Data")
            (DataType "SignalDataArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The signal data.")
        )
    )
    (ComplexDataType (Name "BasicHAVEQUICKModulationStruct")
        (Description "Modulation parameters for Basic HAVE QUICK radio system.")
        (ComplexComponent (FieldName "NETID")
            (DataType "NETIDStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The NET ID being used.")
        )
        (ComplexComponent (FieldName "MWODIndex")
            (DataType "unsigned short")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "This is an index into the \"MWOD Index - WOD Correlation Table\" provided by the exercise agreement. When exercise agreement data is not available or MWOD Index is not known, the default maintenance and training MWOD Index value of 1 shall be used, which corresponds to the WOD values in Table C.2 of IEEE Std 1278.1-2012 Section C.4.2.2.")
        )
        (ComplexComponent (FieldName "Padding")
            (DataType "octet")
            (Cardinality "2")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "TimeOfDay")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The Time of Day (TOD) field for the Basic HAVE QUICK MP record is used to specify a representative Time of Day value for a given radio. A value of zero shall be considered a match to any other value received.")
        )
    )
    (ComplexDataType (Name "BeamAntennaStruct")
        (Description "Specifies the direction, pattern, and polarization of radiation from a radio transmitter's antenna.")
        (ComplexComponent (FieldName "BeamOrientation")
            (DataType "OrientationStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The rotation that transforms the reference coordinate system into the beam coordinate system.")
        )
        (ComplexComponent (FieldName "BeamAzimuthBeamwidth")
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "The full width of the beam to the -3 dB power density points in the x-y plane of the beam coordinate system.")
        )
        (ComplexComponent (FieldName "BeamElevationBeamwidth")
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "The full width of the beam to the -3 dB power density points in the x-z plane of the beam coordinate system.")
        )
        (ComplexComponent (FieldName "ReferenceSystem")
            (DataType "TransmitterAntennaPatternReferenceSystemEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The reference coordinate system with respect to which beam direction is specified.")
        )
        (ComplexComponent (FieldName "Padding")
            (DataType "octet")
            (Cardinality "3")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "Ez")
            (DataType "float")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "The magnitude of the Z-component (in beam coordinates) of the Electrical field at some arbitrary single point in the main beam and in the far field of the antenna.")
        )
        (ComplexComponent (FieldName "Ex")
            (DataType "float")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "The magnitude of the X-component (in beam coordinates) of the Electrical field at some arbitrary single point in the main beam and in the far field of the antenna.")
        )
        (ComplexComponent (FieldName "BeamPhaseAngle")
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "The phase angle between Ez and Ex in radians.")
        )
    )
    (ComplexDataType (Name "BeamSpotShapeStruct")
        (Description "Parameters describing the ellipse shape approximating the irradiance region arriving at the target. The ellipse parameters are measured in the plane perpendicular to the direction of the beam. Refer to IEEE Std 1278.1-2012 Section A.2.4.3 for a detailed description.")
        (ComplexComponent (FieldName "CrossSectionSemiMajorAxis")
            (DataType "float")
            (Cardinality "1")
            (Units "meter (m)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The length of the semi-major axis of an ellipse.")
        )
        (ComplexComponent (FieldName "CrossSectionSemiMinorAxis")
            (DataType "float")
            (Cardinality "1")
            (Units "meter (m)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The length of the semi-minor axis of an ellipse.")
        )
        (ComplexComponent (FieldName "CrossSectionOrientationAngle")
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "The orientation angle from the local 'down' vector to the semi-major axis of an ellipse.")
        )
    )
    (ComplexDataType (Name "BlankingSectorStruct")
        (Description "Specification of a persistent area within a scan volume where emitter power is reduced to an insignificant value. See IEEE Std 1278.1-2012 Section 6.2.21.1 for more information, including Figure 45 illustrating an example.")
        (ComplexComponent (FieldName "LeftAzimuth" [344])
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Indicates the left-most azimuth (clockwise in radians) for which emitted power is reduced. This angle is measured in the x-y plane of the radar's entity coordinate system. The range of permissible values is 0 to 2pi, with zero pointing in the x-direction.")
        )
        (ComplexComponent (FieldName "RightAzimuth" [344])
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Indicates the right-most azimuth (clockwise in radians) for which emitted power is reduced. This angle is measured in the x-y plane of the radar's entity coordinate system. The range of permissible values is 0 to 2pi, with zero pointing in the x-direction.")
        )
        (ComplexComponent (FieldName "LowerElevation" [344])
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Indicates the lowest elevation (in radians) for which emitted power is reduced. This angle is measured positive upward with respect to the x-y plane of the radar's entity coordinate system. The range of permissible values is -pi/2 to pi/2.")
        )
        (ComplexComponent (FieldName "UpperElevation" [344])
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Indicates the highest elevation (in radians) for which emitted power is reduced. This angle is measured positive upward with respect to the x-y plane of the radar's entity coordinate system. The range of permissible values is -pi/2 to pi/2.")
