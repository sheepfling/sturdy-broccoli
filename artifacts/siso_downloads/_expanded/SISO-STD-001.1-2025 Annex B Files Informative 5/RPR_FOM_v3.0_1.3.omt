            (Cardinality "1")
            (Units "radian per second (rad/s)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Acceleration component about the Y axis.")
        )
        (ComplexComponent (FieldName "ZAngularVelocity")
            (DataType "float")
            (Cardinality "1")
            (Units "radian per second (rad/s)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Acceleration component about the Z axis.")
        )
    )
    (ComplexDataType (Name "AntennaLocationIFFDataStruct")
