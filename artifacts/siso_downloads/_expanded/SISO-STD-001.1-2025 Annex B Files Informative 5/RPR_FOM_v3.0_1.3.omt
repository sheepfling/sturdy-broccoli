    (ComplexDataType (Name "Mode5STransponderLocationErrorIFFDataStruct")
        (Description "The specification of errors in location and altitude information transmitted by a Mode 5 or Mode S transponder. Errors are defined as delta values from the truth location of the entity platform. They reflect either human or navigation system errors that might be present and manifest themselves in the data sent in a Mode 5 or Mode S reply or squitter report.If Mode 5 or S location errors are modeled, then this record shall be issued to convey the magnitude of the error for one or more of the location values that could have an error. Fields with no errors shall have all bits of that field set to zero.")
        (ComplexComponent (FieldName "DeltaLatitude")
            (DataType "long")
            (Cardinality "1")
            (Units "90/(2^31) degree (deg)")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The delta error in latitude from the true latitude computed for the entity with a Mode 5 or S transponder. Delta latitude shall be represented as two's complement coded latitude with the Most Significant Bit (MSB) equal to -90 degrees. All bits of this field shall be set to zero if there is no error in latitude.")
        )
        (ComplexComponent (FieldName "DeltaLongitude")
            (DataType "long")
            (Cardinality "1")
            (Units "180/(2^31) degree (deg)")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The delta error in longitude from the true longitude computed for the entity. Delta longitude shall be represented as two's complement coded longitude with the Most Significant Bit (MSB) equal to -180 degrees. All bits of this field shall be set to zero if there is no error in longitude.")
        )
        (ComplexComponent (FieldName "DeltaMode5SAltitude")
            (DataType "DeltaMode5SAltitudeStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The delta error in Mode 5 / Mode S Altitude of the entity with a Mode 5 or S transponder. All bits of this field shall be set to zero if there is no error in Mode 5 / Mode S altitude.")
        )
        (ComplexComponent (FieldName "Padding")
            (DataType "octet")
            (Cardinality "3")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "DeltaBarometricAltitude")
            (DataType "DeltaBarometricAltitudeStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The delta error in barometric altitude of the entity. All bits of this field shall be set to zero if there is no error in barometric altitude.")
        )
    )
