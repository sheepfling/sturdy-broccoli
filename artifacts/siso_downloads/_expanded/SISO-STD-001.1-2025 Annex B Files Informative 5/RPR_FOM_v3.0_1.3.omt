    (ComplexDataType (Name "HighFidelityHAVEQUICKStruct")
        (Description "Specification of a High Fidelity HAVE QUICK record. See IEEE Std 1278.1-2012 Section C.4.2.3 for more information.")
        (ComplexComponent (FieldName "NETID")
            (DataType "NETIDStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Contains the NET ID being used.")
        )
        (ComplexComponent (FieldName "TODTransmitIndicator")
            (DataType "HighFidelityHAVEQUICKTODTransmitIndicatorEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Indicates whether a TOD is being transmitted. This is also referred to as a Mickey.")
        )
        (ComplexComponent (FieldName "Padding")
            (DataType "octet")
            (Cardinality "3")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "TODDelta")
            (DataType "long")
            (Cardinality "1")
            (Units "100 microsecond")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the difference between the transceiver internal clock and the reference clock, which is the amount of clock drift that has occurred. This field is expressed in units of hundreds of microseconds. The reference clock is an internally simulated clock that simulates a drift or difference from the reference value of zero, with which all simulated HAVE QUICK radios are assumed to be synchronized. This drift shall be placed in the TOD Delta field of the transmitting radio. Receiving radios may then use the TOD Delta field to emulate audio effects (such as clipped or garbled audio) due to HAVE QUICK time mismatches. If the TOD Delta field is zero, the radio is considered to be synchronized with the reference clock for all of the High-Fidelity HAVE QUICK radios participating in the exercise.")
        )
        (ComplexComponent (FieldName "WOD1")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Word of Day (WOD) 1. All six WODs collectively are called a Multiple Word of Day (MWOD). May also be specified as segment 1 or CH20.")
        )
        (ComplexComponent (FieldName "WOD2")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Word of Day (WOD) 2. All six WODs collectively are called a Multiple Word of Day (MWOD). May also be specified as segment 2 or CH19.")
        )
        (ComplexComponent (FieldName "WOD3")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Word of Day (WOD) 3. All six WODs collectively are called a Multiple Word of Day (MWOD). May also be specified as segment 3 or CH18.")
        )
        (ComplexComponent (FieldName "WOD4")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Word of Day (WOD) 4. All six WODs collectively are called a Multiple Word of Day (MWOD). May also be specified as segment 4 or CH17.")
        )
        (ComplexComponent (FieldName "WOD5")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Word of Day (WOD) 5. All six WODs collectively are called a Multiple Word of Day (MWOD). May also be specified as segment 5 or CH16.")
        )
        (ComplexComponent (FieldName "WOD6")
            (DataType "unsigned long")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
