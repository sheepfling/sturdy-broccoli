            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The type of encoding used for the audio data.")
        )
        (ComplexComponent (FieldName "Padding")
            (DataType "octet")
            (Cardinality "2")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
