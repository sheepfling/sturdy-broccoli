        (Attribute (Name "TCAS_I_II_Type")
            (DataType "TCASIIITypeEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Static)
            (UpdateCondition "NA")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates whether a TCAS system is a TCAS I (0) or TCAS II (1) system when the TCAS/ACAS Type field does not indicate a TCAS III system. If the TCAS/ACAS Type field contains a nonzero value, then this field shall be set to No Statement (0).")
        )
        (Attribute (Name "BasicAdvancedIndicator")
            (DataType "TCASACASBasicAdvancedIndicatorEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Static)
            (UpdateCondition "NA")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates whether this TCACS/ACAS object contains Basic (0) or Advanced (1) data. Basic data is the minimum required to be set by any TCAS/ACAS capable interrogator or transponder. Advanced data means that the record contains additional data fields for a higher fidelity simulation of TCAS/ACAS capabilities. The attributes TCAS_ACASType, TCAS_ACASIndicator, and SoftwareVersion are not applicable to Basic and required for Advanced data.")
        )
        (Attribute (Name "TCAS_ACASType")
            (DataType "TCASACASTypeEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Static)
            (UpdateCondition "NA")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates the type of TCAS/ACAS system other than a TCAS I or II system, if known, or shall be set to No Statement (0) if not known.")
        )
        (Attribute (Name "TCAS_ACASIndicator")
            (DataType "TCASACASIndicatorEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Static)
            (UpdateCondition "NA")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates whether the record applies to a TCAS (0) or an ACAS (1) system.")
        )
        (Attribute (Name "SoftwareVersion")
            (DataType "TCASACASSoftwareVersionEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Static)
            (UpdateCondition "NA")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Indicates the software version of the TCAS/ACAS system if known or set to No Statement (0) if not known.")
        )
    )
