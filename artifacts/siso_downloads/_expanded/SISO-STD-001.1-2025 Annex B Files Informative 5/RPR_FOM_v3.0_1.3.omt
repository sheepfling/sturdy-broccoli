    (ComplexDataType (Name "FalseTargetsStruct")
        (Description "Specification of discrete values that are associated with false targets jamming that cannot be referenced to an emitter mode. The values provided in the record shall be considered valid only for the victim radar beams listed in the jamming beam's JammedObjectIdentifiers. See IEEE Std 1278.1-2012 Section 6.2.21.3 for more information, including Figure 48 illustrating the effect.")
        (ComplexComponent (FieldName "FalseTargetCount")
            (DataType "unsigned short")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the number of false targets presented to the victim radar.")
        )
        (ComplexComponent (FieldName "Padding")
            (DataType "octet")
            (Cardinality "2")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "WalkSpeed" [347])
            (DataType "float")
            (Cardinality "1")
            (Units "meter per second (m/s)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the speed (in meters per second) at which false targets move toward the victim radar. Negative values shall indicate a velocity away from the victim radar.")
        )
        (ComplexComponent (FieldName "WalkAcceleration" [348])
            (DataType "float")
            (Cardinality "1")
            (Units "meter per second squared (m/(s^2))")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Specifies the rate (in meters per second squared) at which false targets accelerate toward the victim radar. Negative values shall indicate an acceleration direction away from the victim radar.")
        )
        (ComplexComponent (FieldName "MaximumWalkDistance" [345])
            (DataType "float")
            (Cardinality "1")
            (Units "meter (m)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the distance (in meters) that a false target is to walk before it pauses in range.")
        )
        (ComplexComponent (FieldName "KeepTime" [346])
            (DataType "float")
            (Cardinality "1")
            (Units "second")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Specifies the simulation time (in seconds) that a false target is to be held at the MaximumWalkDistance before it resets to its initial position.")
        )
        (ComplexComponent (FieldName "EchoSpacing" [340])
            (DataType "float")
            (Cardinality "1")
            (Units "meter (m)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the distance between false targets in meters. A positive value for this field shall indicate that the second and subsequent false targets appear at the given spacing relative to the first false target away from the victim radar (i.e., at increasing ranges from the victim). A negative value shall indicate that the second and subsequent false targets appear toward the victim radar relative to the first false target.")
        )
        (ComplexComponent (FieldName "FirstTargetOffset")
            (DataType "float")
            (Cardinality "1")
            (Units "meter (m)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Sets the position of the first false target relative to the jamming entity in meters. A positive value for this field shall indicate that the first target appears at the given distance relative to the jamming entity away from the victim radar (i.e., at an increasing range from the victim). A negative value shall indicate the first false target appears toward the victim radar relative to the jamming entity. A value of zero shall place the first false target at the same position as the jamming entity.")
        )
    )
    (ComplexDataType (Name "FederateIdentifierStruct")
        (Description "Unique identification of the simulation application (federate) in an exercise, or a symbolic group address referencing multiple simulation applications. Based on the Simulation Address record as specified in IEEE Std 1278.1-2012 Section 6.2.80.")
        (ComplexComponent (FieldName "SiteID")
            (DataType "unsigned short")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Each site participating in an event (e.g., training exercise, experiment, and test) shall be assigned a unique SiteID that is different from any other site that is part of the same event. The range of valid SiteID values that may be assigned to a specific site is from 1 to 65 534. The manner in which SiteID values are assigned is part of federation agreements. A SiteID value of NO_SITE (fixed value: 0) indicates no specific site. A SiteID value of ALL_SITES (fixed value: FFFF (H)) indicates all sites.")
        )
        (ComplexComponent (FieldName "ApplicationID")
            (DataType "unsigned short")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Each application (federate) participating in an event (e.g., training exercise) shall be assigned a unique ApplicationID value for the site with which the application is associated. An application may be assigned multiple ApplicationID values, see IEEE Std 1278.1-2012 Section 4.2.3.3. The range of valid ApplicationID values that may be assigned to a specific application is from 1 to 65 534. The manner in which ApplicationID values are assigned is part of federation agreements. An ApplicationID value of NO_APPLIC (fixed value: 0) indicates no specific application. An ApplicationID value of ALL_APPLIC (fixed value: FFFF (H)) indicates all applications.")
        )
    )
