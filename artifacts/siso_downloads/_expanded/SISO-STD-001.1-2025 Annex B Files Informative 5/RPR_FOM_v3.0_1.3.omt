        (Parameter (Name "Fusing" [310])
            (DataType "MineFusingStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the primary and secondary fuse and anti-handling device for each mine.")
        )
        (Parameter (Name "MineEmplacementTime" [323])
            (DataType "ClockTimeStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the real-world (UTC) emplacement time of the mine.")
        )
        (Parameter (Name "MineEntityIdentifier" [319])
            (DataType "MineIdentifierArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Identifies the mine entity identifier; the MineEntityID in conjunction with the MinefieldID form the unique identifier for each mine.")
        )
        (Parameter (Name "MinefieldIdentifier" [319])
            (DataType "RTIobjectId")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Identifies the minefield to which the mines belong.")
        )
        (Parameter (Name "MineLocation" [319])
            (DataType "LocationStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the location of the mine relative to the minefield location.")
        )
        (Parameter (Name "MineOrientation" [310])
            (DataType "OrientationStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the orientation of the center axis direction of fire of the mine, relative to the minefield Coordinate System.")
        )
        (Parameter (Name "MineType" [319])
            (DataType "EntityTypeStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the type of each mine contained within the minefield interaction.")
        )
        (Parameter (Name "NumberOfRecords" [319])
            (DataType "octet")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the total number of minefield records being published in response to a Minefield Query interaction.")
        )
        (Parameter (Name "NumberTripDetonationWires" [311])
            (DataType "UnsignedInteger8Array")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the number of trip detonation wires that exist for each mine.")
        )
        (Parameter (Name "NumberWireVertices" [308])
            (DataType "UnsignedInteger8Array")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the number of vertices for each trip wire.")
        )
        (Parameter (Name "PaintScheme" [323])
            (DataType "MinefieldDataPaintSchemeStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the camouflage scheme/color of the mine.")
        )
        (Parameter (Name "RecordSequenceNumber" [319])
            (DataType "octet")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the number of the current record in a sequence of minefield records published in response to a Minefield Query interaction.")
        )
        (Parameter (Name "Reflectance" [323])
            (DataType "MineDielectricDifferenceArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the local dielectric difference between the mine and the surrounding soil.")
        )
        (Parameter (Name "RequestIdentifier" [319])
            (DataType "octet")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Identifies the matching response to a request for mine information from the minefield simulation made by means of a Minefield Query interaction.")
        )
        (Parameter (Name "RequestingIdentifier" [319])
            (DataType "FederateIdentifierStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Identifies the simulation application that requested the information from the minefield simulation in QRP (Query Response Protocol) mode.")
        )
        (Parameter (Name "ScalarDetectionCoefficient" [323])
            (DataType "UnsignedInteger8Array")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the coefficient to be utilized to insure proper correlation between detectors located on different simulation platforms.")
        )
        (Parameter (Name "SensorTypes" [319])
            (DataType "MinefieldSensorTypeVariantStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "In QRP mode, specifies the requesting sensor types which were specified in the minefield query whereas in Heartbeat mode, specifies the sensor types that are being served by the minefield.")
        )
        (Parameter (Name "SnowBurialDepthOffset" [323])
            (DataType "DepthMeterFloat32Array")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the offset of the origin of the mine coordinate system with respect to the snow surface.")
        )
        (Parameter (Name "ThermalContrast" [323])
            (DataType "TemperatureDegreeCelsiusFloat32Array")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the temperature difference between the mine and the surrounding soil in degrees Centigrade.")
        )
        (Parameter (Name "WaterBurialDepthOffset" [323])
