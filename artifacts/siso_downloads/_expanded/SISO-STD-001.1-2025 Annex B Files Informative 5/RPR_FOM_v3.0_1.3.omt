    (Class (ID 69)
        (Name "Mode1Transponder")
        (PSCapabilities PS)
        (Description "IFF transponder Mode 1 capability.")
        (SuperClass 67)
        (Attribute (Name "Code")
            (DataType "unsigned short")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Mode 1 code. For Mark X/XII systems, two octal values in the range 00 to 73 with the first digit in the range 0 to 7 and the second digit in the range 0 to 3 reading left to right. The first (left) digit is Code Element 2 (A) and occupies bits 3 to 5, and the second (right) digit is Code Element 1 (B) and occupies bits 0 to 2. Mark XIIA systems may employ extended Mode 1 codes, four octal values in the range 0000 to 7777 (as per Mode 2 and Mode 3/A codes). The attribute ExtendedCodeIsSet indicates whether or not an extended code has been set. If an extended Mode 1 code has been set, Mark X/XII interrogators need to extract bits 9-11 (Code Element A) and bits 6-7 (Code Element B).")
        )
        (Attribute (Name "ExtendedCodeIsSet" [349])
            (DataType "RPRboolean")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (UpdateType Conditional)
            (UpdateCondition "On change")
            (TransferAccept TA)
            (UpdateReflect UR)
            (Description "Specifies whether or not Mark XIIA Enhanced Mode 1 is on.")
        )
    )
