(DIF HLA-OMT v1.3 (TYPE Single))
(ObjectModel 
    (Name "SISO-STD-001.1-2025 - Real-time Platform Reference FOM")
    (VersionNumber "3.0")
    (Type FOM)
    (Purpose "The RPR FOM supports interoperability for real-time, platform oriented defense simulation.")
    (ApplicationDomain "All domains")
