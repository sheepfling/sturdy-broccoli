            (DataType "unsigned long")
            (Cardinality "1")
            (Units "Hertz")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The number of samples per second in the audio data.")
        )
        (ComplexComponent (FieldName "DataLength")
            (DataType "unsigned short")
            (Cardinality "1")
            (Units "bit")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The length of the signal data.")
        )
        (ComplexComponent (FieldName "Padding_1")
            (DataType "octet")
            (Cardinality "2")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "SampleCount")
