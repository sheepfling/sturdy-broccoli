    (ComplexDataType (Name "AccelerationVectorStruct")
        (Description "The magnitude of the change in linear velocity over time.")
        (ComplexComponent (FieldName "XAcceleration")
            (DataType "float")
            (Cardinality "1")
            (Units "meter per second squared (m/(s^2))")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Acceleration component along the X axis.")
        )
        (ComplexComponent (FieldName "YAcceleration")
            (DataType "float")
            (Cardinality "1")
            (Units "meter per second squared (m/(s^2))")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Acceleration component along the Y axis.")
        )
        (ComplexComponent (FieldName "ZAcceleration")
            (DataType "float")
            (Cardinality "1")
            (Units "meter per second squared (m/(s^2))")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Acceleration component along the Z axis.")
        )
    )
    (ComplexDataType (Name "AggregateMarkingStruct" [280])
        (Description "Unique marking associated with an aggregate.")
        (ComplexComponent (FieldName "MarkingEncodingType")
            (DataType "EntityMarkingCharacterSetEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The type of marking.")
        )
        (ComplexComponent (FieldName "MarkingData")
            (DataType "MarkingArray31")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The marking itself.")
        )
    )
    (ComplexDataType (Name "AngleDeceptionAngleDataStruct")
        (Description "Data defining the angle deception jamming in one plane.")
        (ComplexComponent (FieldName "Offset" [344])
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Indicates the relative angle at which the deceptive radar returns are centered. This angle is measured with respect to the x-y plane of the victim radar's entity coordinate system. This angle is measured in radians from the victim radar entity's azimuth/elevation for the true jammer position to the center of the range of azimuths/elevations in which deceptive radar returns are perceived.For azimuth offset, positive and negative values indicate that the perceived positions of the jammer are right and left of the true position of the jammer, respectively. The range of permissible values is -pi to pi.For elevation offset, positive and negative values indicate that the perceived positions of the jammer are above and below the true position of the jammer, respectively. The range of permissible values is -pi/2 to pi/2.")
        )
        (ComplexComponent (FieldName "Width" [344])
            (DataType "float")
            (Cardinality "1")
            (Units "radian (rad)")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Indicates the range through which the deceptive radar returns are perceived, centered on the Offset.For azimuth width, the range of permissible values is 0 to 2pi radians.For elevation width, the range of permissible values is 0 to pi radians.")
        )
        (ComplexComponent (FieldName "PullRate" [342])
            (DataType "float")
            (Cardinality "1")
            (Units "radian per second (rad/s)")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Indicates the rate (in radians per second) at which the Offset value is changing.For azimuth pull rate, positive and negative values indicate that the azimuth offset is moving to the right or left, respectively.For elevation pull rate, positive and negative values indicate that the elevation offset is moving up or down, respectively.")
        )
        (ComplexComponent (FieldName "PullAcceleration" [343])
            (DataType "float")
            (Cardinality "1")
            (Units "radian per second squared (rad/(s^2))")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Indicates the rate (in radians per second squared) at which the PullRate value is changing.Azimuth Pull Acceleration is defined as positive to the right and negative to the left.Elevation Pull Acceleration is defined as positive to upward and negative downward.")
        )
    )
    (ComplexDataType (Name "AngleDeceptionStruct")
        (Description "Specification of discrete values associated with angle deception jamming that cannot be referenced to an emitter mode. The values provided in the record shall be considered valid only for the victim radar beams listed in the jamming beam's JammedObjectIdentifiers. See IEEE Std 1278.1-2012 Section 6.2.21.2 for more information, including Figure 46 and Figure 47 illustrating the concept of angle deception jamming.")
        (ComplexComponent (FieldName "AzimuthAngleData")
            (DataType "AngleDeceptionAngleDataStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The azimuth relative angle, width, pull rate, and pull acceleration.")
        )
        (ComplexComponent (FieldName "ElevationAngleData")
            (DataType "AngleDeceptionAngleDataStruct")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The elevation relative angle, width, pull rate, and pull acceleration.")
        )
    )
    (ComplexDataType (Name "AngularVelocityVectorStruct")
        (Description "The rate at which the orientation is changing over time, in body coordinates.")
        (ComplexComponent (FieldName "XAngularVelocity")
            (DataType "float")
            (Cardinality "1")
            (Units "radian per second (rad/s)")
            (Resolution "N/A")
