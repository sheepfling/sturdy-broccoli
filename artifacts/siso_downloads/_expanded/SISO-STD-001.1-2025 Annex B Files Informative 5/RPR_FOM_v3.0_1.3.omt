            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the offset of the origin of the mine coordinate system with respect to the water surface.")
        )
        (Parameter (Name "WireVertices" [309])
            (DataType "LocationStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Specifies the locations of vertices in a trip wire.")
        )
