        )
        (ComplexComponent (FieldName "TargetEnergyDepositions")
            (DataType "TargetEnergyDepositionStructArray")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Zero or more non-self-identifying target energy deposition data sets.")
        )
    )
    (ComplexDataType (Name "ArticulatedPartParameterTypeStruct")
        (Description "Specifies the parameter type of an attached part, including the type class and type metric.")
        (ComplexComponent (FieldName "ParameterTypeClass")
            (DataType "ArticulatedPartsTypeClassEnum32")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The type class uniquely identifies a particular articulated part on a given entity type. Guidance for uniquely assigning type classes to an entity's articulated parts is given in Section 4.8 of the enumeration document (SISO-REF-010).")
        )
        (ComplexComponent (FieldName "ParameterTypeMetric")
            (DataType "ArticulatedPartsTypeMetricEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The type metric uniquely identifies the transformation to be applied to the articulated part.")
        )
    )
    (ComplexDataType (Name "ArticulatedPartVPStruct")
        (Description "Structure to specify a movable part or a combination of a moveable/attached part of an entity. Based on the Articulated Part VP record as specified in IEEE Std 1278.1-2012 Section 6.2.94.2.")
        (ComplexComponent (FieldName "ChangeIndicator")
            (DataType "octet")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Indicator of a change to the part. This field shall be set to zero for each exercise and sequentially incremented by one for each change in articulation parameters. In the case where all possible values are exhausted, the numbers shall be reused beginning at zero.")
        )
        (ComplexComponent (FieldName "Padding")
            (DataType "octet")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "PartAttachedTo")
            (DataType "unsigned short")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "Identification of the articulated part to which this articulation parameter is attached. This field shall contain the value zero if the articulated part is attached directly to the entity.")
        )
        (ComplexComponent (FieldName "ParameterTypeClass")
            (DataType "ArticulatedPartsTypeClassEnum32")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The type class uniquely identifies a particular articulated part on a given entity type. Guidance for uniquely assigning type classes to an entity's articulated parts is given in Section 4.8 of the enumeration document (SISO-REF-010).")
        )
        (ComplexComponent (FieldName "ParameterTypeMetric")
            (DataType "ArticulatedPartsTypeMetricEnum8")
            (Cardinality "1")
            (Accuracy "perfect")
            (AccuracyCondition "always")
            (Description "The type metric uniquely identifies the transformation to be applied to the articulated part.")
        )
        (ComplexComponent (FieldName "Padding_1")
            (DataType "octet")
            (Cardinality "3")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "perfect")
            (AccuracyCondition "always")
        )
        (ComplexComponent (FieldName "Value" [203])
            (DataType "float")
            (Cardinality "1")
            (Units "N/A")
            (Resolution "N/A")
            (Accuracy "N/A")
            (Description "Value of the transformation to be applied to the articulated part.")
        )
    )
