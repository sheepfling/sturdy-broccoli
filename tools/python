    hla2010_shell_run_workspace_python "$python_bin" -m pytest -q tests/requirements/test_ieee_1516_2025_requirements_registry.py
    hla2010_shell_run_workspace_python "$python_bin" -m pytest -q tests/test_rti1516_2025_python2025_runtime.py -k "primary_python_rti_runs_support_factory_and_decode_scenario_without_wrapper_adapter or primary_python_rti_accepts_snake_case_aliases_for_direct_runtime_surface or primary_python_rti_runs_raw_callback_control_flow_without_wrapper_adapter"
