#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT_DIR/scripts/lib/shell.sh"
hla2010_shell_init "tools/python"

usage() {
  cat <<'EOF'
usage: ./tools/python [verify|verify-fast|verify-routes|verify-routes-preflight|help]

Canonical Python / repo-green operator flow:
  ./tools/python verify                  # run the repo-green verification lane
  ./tools/python verify-fast             # run the fast Python/operator lane
  ./tools/python verify-routes           # run Python direct-vs-gRPC route parity checks
  ./tools/python verify-routes-preflight # report whether python-grpc is runnable here

This is the human-facing wrapper over ./scripts/ci/repo_green.sh.
Use ./tools/certi-easy and ./tools/pitch for vendor-runtime operator flows.
EOF
}

case "${1:-verify}" in
  help|-h|--help)
    usage
    ;;
  verify)
    shift
    exec bash "$ROOT_DIR/scripts/ci/repo_green.sh" "$@"
    ;;
  verify-fast)
    shift
    if [[ -n "${HLA2010_PYTHON_VERIFY_FAST_DELEGATE:-}" ]]; then
      exec "${HLA2010_PYTHON_VERIFY_FAST_DELEGATE}" "$@"
    fi
    exec bash "$ROOT_DIR/scripts/ci/python_fast.sh" "$@"
    ;;
  verify-routes)
    shift
    if [[ -n "${HLA2010_PYTHON_VERIFY_ROUTES_DELEGATE:-}" ]]; then
      exec "${HLA2010_PYTHON_VERIFY_ROUTES_DELEGATE}" "$@"
    fi
    python_bin="${HLA2010_PYTHON_VERIFY_ROUTES_PYTHON:-python3}"
    hla2010_shell_run_workspace_python "$python_bin" -m pytest -q tests/scenarios/test_python_route_parity.py "$@"
    hla2010_shell_run_workspace_python "$python_bin" -m pytest -q tests/transport/test_grpc_transport_python_server.py
    hla2010_shell_run_workspace_python "$python_bin" scripts/run_python_route_parity_matrix.py
    hla2010_shell_run_workspace_python "$python_bin" examples/target_radar_simulation.py --backend python --steps 5
    hla2010_shell_run_workspace_python "$python_bin" examples/target_radar_simulation.py --backend python-grpc --steps 5
    exit $?
    ;;
  verify-routes-preflight)
    shift
    if [[ -n "${HLA2010_PYTHON_VERIFY_ROUTES_PREFLIGHT_DELEGATE:-}" ]]; then
      exec "${HLA2010_PYTHON_VERIFY_ROUTES_PREFLIGHT_DELEGATE}" "$@"
    fi
    python_bin="${HLA2010_PYTHON_VERIFY_ROUTES_PYTHON:-python3}"
    exec "$python_bin" "$ROOT_DIR/scripts/check_python_route_preflight.py" "$@"
    ;;
  *)
    echo "error: unknown subcommand: $1" >&2
    usage >&2
    exit 2
    ;;
esac
