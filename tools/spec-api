#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT_DIR/scripts/lib/shell.sh"
hla2010_shell_init "tools/spec-api"

usage() {
  cat <<'EOF'
usage: ./tools/spec-api [generate|check|help]

Canonical API metadata flow:
  ./tools/spec-api generate
  ./tools/spec-api check

This is the human-facing wrapper over `scripts/generate_api_metadata.py`.
EOF
}

python_bin="$(hla2010_shell_python_bin)"

case "${1:-check}" in
  help|-h|--help)
    usage
    ;;
  generate|check)
    subcommand="$1"
    shift
    hla2010_shell_run_workspace_python "$python_bin" "$ROOT_DIR/scripts/generate_api_metadata.py" "$subcommand" "$@"
    ;;
  *)
    echo "error: unknown subcommand: $1" >&2
    usage >&2
    exit 2
    ;;
esac
