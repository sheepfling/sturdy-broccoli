#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT_DIR/scripts/lib/shell.sh"
hla2010_shell_init "tools/vendor-parity"

usage() {
  cat <<'EOF'
usage: ./tools/vendor-parity [args...]

Canonical vendor parity artifact flow:
  ./tools/vendor-parity
  ./tools/vendor-parity --output-dir artifacts/my_vendor_parity_artifacts

This is the human-facing wrapper over `scripts/run_vendor_parity_artifacts.py`.
EOF
}

python_bin="$(hla2010_shell_python_bin)"

case "${1:-run}" in
  help|-h|--help)
    usage
    ;;
  run)
    if [[ $# -gt 0 ]]; then
      shift
    fi
    "$python_bin" "$ROOT_DIR/scripts/run_vendor_parity_artifacts.py" "$@"
    ;;
  --*)
    "$python_bin" "$ROOT_DIR/scripts/run_vendor_parity_artifacts.py" "$@"
    ;;
  *)
    echo "error: unknown subcommand: $1" >&2
    usage >&2
    exit 2
    ;;
esac
