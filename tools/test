#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
  cat <<'EOF'
usage: ./tools/test [pytest-args...]

Canonical local pytest wrapper:
  ./tools/test
  ./tools/test tests/test_operator_surface_policy.py
  ./tools/test tests/test_python_route_examples.py::test_python_route_federate_example_runs_for_supported_editions
  ./tools/test -k ownership --lf
  ./tools/test tests/transport --ff

This is the human-facing wrapper over `./scripts/ci/test.py`, with
`./scripts/ci/test.sh` retained as a compatibility alias.
EOF
}

python_bin() {
  if [[ -x "$ROOT_DIR/.venv/bin/python" ]]; then
    printf '%s\n' "$ROOT_DIR/.venv/bin/python"
  elif command -v python3 >/dev/null 2>&1; then
    command -v python3
  else
    command -v python
  fi
}

case "${1:-}" in
  help|-h|--help)
    usage
    ;;
  *)
    exec "$(python_bin)" "$ROOT_DIR/scripts/ci/test.py" "$@"
    ;;
esac
