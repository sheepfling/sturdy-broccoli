#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
  cat <<'EOF'
usage: ./tools/vendor-green [profile]

Canonical strict vendor-runtime lane:
  ./tools/vendor-green matrix
  ./tools/vendor-green certi
  ./tools/vendor-green pitch

This is the human-facing wrapper over `./scripts/ci/vendor_green.sh`.
EOF
}

case "${1:-}" in
  help|-h|--help)
    usage
    ;;
  *)
    exec bash "$ROOT_DIR/scripts/ci/vendor_green.sh" "$@"
    ;;
esac
