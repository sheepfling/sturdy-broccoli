<?xml version="1.0" encoding="utf-8"?>
<objectModel xmlns="http://standards.ieee.org/IEEE1516-2025"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://standards.ieee.org/IEEE1516-2025 IEEE1516-DIF-2025.xsd">
    <modelIdentification>
        <name>Encoding Smoke Test FOM</name>
        <type>FOM</type>
        <version>1.0</version>
        <modificationDate>2026-06-17</modificationDate>
        <securityClassification>Unclassified</securityClassification>
        <copyright>NA</copyright>
        <releaseRestriction>NA</releaseRestriction>
        <purpose>Small data-type-focused FOM module for language-shim encoding tests.</purpose>
        <applicationDomain>Test and Evaluation</applicationDomain>
    </modelIdentification>
    <objects>
        <objectClass>
            <name>HLAobjectRoot</name>
            <sharing>Neither</sharing>
            <objectClass>
                <name>Track</name>
                <sharing>PublishSubscribe</sharing>
                <attribute>
                    <name>Id</name>
                    <dataType>TrackId</dataType>
                    <updateType>Conditional</updateType>
                    <updateCondition>On change</updateCondition>
                    <valueRequired>true</valueRequired>
                    <ownership>NoTransfer</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <transportation>HLAreliable</transportation>
                    <order>Receive</order>
                </attribute>
                <attribute>
                    <name>State</name>
                    <dataType>TrackState</dataType>
                    <updateType>Conditional</updateType>
                    <updateCondition>On change</updateCondition>
                    <valueRequired>true</valueRequired>
                    <ownership>NoTransfer</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <transportation>HLAreliable</transportation>
                    <order>Receive</order>
                </attribute>
            </objectClass>
        </objectClass>
    </objects>
    <interactions>
        <interactionClass>
            <name>HLAinteractionRoot</name>
            <interactionClass>
                <name>TrackReport</name>
                <sharing>PublishSubscribe</sharing>
                <transportation>HLAreliable</transportation>
                <order>Receive</order>
                <parameter>
                    <name>Contact</name>
                    <dataType>SensorContact</dataType>
                </parameter>
            </interactionClass>
        </interactionClass>
    </interactions>
    <dimensions/>
    <transportations>
        <transportation>
            <name>HLAreliable</name>
            <reliable>Yes</reliable>
        </transportation>
    </transportations>
    <dataTypes>
        <basicDataRepresentations/>
        <simpleDataTypes>
            <simpleData>
                <name>TrackId</name>
                <representation>HLAinteger32BE</representation>
                <units>NA</units>
                <resolution>1</resolution>
                <accuracy>Perfect</accuracy>
            </simpleData>
            <simpleData>
                <name>Latitude</name>
                <representation>HLAfloat64BE</representation>
                <units>degree</units>
                <resolution>1e-9</resolution>
                <accuracy>Approximate</accuracy>
            </simpleData>
            <simpleData>
                <name>Longitude</name>
                <representation>HLAfloat64BE</representation>
                <units>degree</units>
                <resolution>1e-9</resolution>
                <accuracy>Approximate</accuracy>
            </simpleData>
            <simpleData>
                <name>Altitude</name>
                <representation>HLAfloat32BE</representation>
                <units>m</units>
                <resolution>0.1</resolution>
                <accuracy>Approximate</accuracy>
            </simpleData>
        </simpleDataTypes>
        <referenceDataTypes/>
        <enumeratedDataTypes>
            <enumeratedData>
                <name>SensorKind</name>
                <representation>HLAinteger32BE</representation>
                <enumerator>
                    <name>Radar</name>
                    <value>1</value>
                </enumerator>
                <enumerator>
                    <name>Iff</name>
                    <value>2</value>
                </enumerator>
                <enumerator>
                    <name>Passive</name>
                    <value>3</value>
                </enumerator>
            </enumeratedData>
        </enumeratedDataTypes>
        <arrayDataTypes>
            <arrayData>
                <name>TrackHistory</name>
                <dataType>Position</dataType>
                <cardinality>Dynamic</cardinality>
                <encoding>HLAvariableArray</encoding>
            </arrayData>
            <arrayData>
                <name>FixedFourTrackIds</name>
                <dataType>TrackId</dataType>
                <cardinality>4</cardinality>
                <encoding>HLAfixedArray</encoding>
            </arrayData>
        </arrayDataTypes>
        <fixedRecordDataTypes>
            <fixedRecordData>
                <name>Position</name>
                <encoding>HLAfixedRecord</encoding>
                <field>
                    <name>Latitude</name>
                    <dataType>Latitude</dataType>
                </field>
                <field>
                    <name>Longitude</name>
                    <dataType>Longitude</dataType>
                </field>
                <field>
                    <name>Altitude</name>
                    <dataType>Altitude</dataType>
                </field>
            </fixedRecordData>
            <fixedRecordData>
                <name>RadarContact</name>
                <encoding>HLAfixedRecord</encoding>
                <field>
                    <name>RangeMeters</name>
                    <dataType>HLAfloat32BE</dataType>
                </field>
                <field>
                    <name>AzimuthRadians</name>
                    <dataType>HLAfloat32BE</dataType>
                </field>
            </fixedRecordData>
            <fixedRecordData>
                <name>IffContact</name>
                <encoding>HLAfixedRecord</encoding>
                <field>
                    <name>Code</name>
                    <dataType>HLAinteger32BE</dataType>
                </field>
            </fixedRecordData>
            <fixedRecordData>
                <name>TrackState</name>
                <encoding>HLAfixedRecord</encoding>
                <field>
                    <name>Id</name>
                    <dataType>TrackId</dataType>
                </field>
                <field>
                    <name>Where</name>
                    <dataType>Position</dataType>
                </field>
                <field>
                    <name>Name</name>
                    <dataType>HLAunicodeString</dataType>
                </field>
            </fixedRecordData>
        </fixedRecordDataTypes>
        <variantRecordDataTypes>
            <variantRecordData>
                <name>SensorContact</name>
                <discriminant>Kind</discriminant>
                <dataType>SensorKind</dataType>
                <alternative>
                    <enumerator>Radar</enumerator>
                    <name>Radar</name>
                    <dataType>RadarContact</dataType>
                </alternative>
                <alternative>
                    <enumerator>Iff</enumerator>
                    <name>Iff</name>
                    <dataType>IffContact</dataType>
                </alternative>
                <alternative>
                    <enumerator>HLAother</enumerator>
                    <name>Other</name>
                    <dataType>HLAopaqueData</dataType>
                </alternative>
                <encoding>HLAvariantRecord</encoding>
            </variantRecordData>
        </variantRecordDataTypes>
    </dataTypes>
</objectModel>
