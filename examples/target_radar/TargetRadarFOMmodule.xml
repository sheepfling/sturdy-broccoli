<?xml version="1.0" encoding="utf-8"?>
<objectModel xmlns="http://standards.ieee.org/IEEE1516-2010" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://standards.ieee.org/IEEE1516-2010 http://standards.ieee.org/downloads/1516/1516.2-2010/IEEE1516-DIF-2010.xsd">
  <modelIdentification>
    <name>Target Radar FOM Module</name>
    <type>FOM</type>
    <version>0.2</version>
    <modificationDate>2026-06-05</modificationDate>
    <securityClassification>Unclassified</securityClassification>
    <purpose>Minimal FOM for a single flying target and radar track-data scenario.</purpose>
    <applicationDomain>HLA API development and integration testing</applicationDomain>
    <description>Defines HLAobjectRoot.Target, HLAobjectRoot.Track, and a TrackReport interaction used by examples/target_radar_simulation.py.</description>
  </modelIdentification>
  <objects>
    <objectClass>
      <name>HLAobjectRoot</name>
      <objectClass>
        <name>Target</name>
        <sharing>PublishSubscribe</sharing>
        <semantics>Single airborne target.</semantics>
        <attribute><name>Position</name><dataType>Vec3Float64BE</dataType><updateType>Periodic</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Target position in meters.</semantics></attribute>
        <attribute><name>Velocity</name><dataType>Vec3Float64BE</dataType><updateType>Periodic</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Target velocity in meters per second.</semantics></attribute>
        <attribute><name>RCS</name><dataType>HLAfloat64BE</dataType><updateType>Conditional</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Radar cross section in square meters. Radar federates request this attribute using requestAttributeValueUpdate.</semantics></attribute>
      </objectClass>
      <objectClass>
        <name>Track</name>
        <sharing>PublishSubscribe</sharing>
        <semantics>Radar-produced track object.</semantics>
        <attribute><name>TargetName</name><dataType>HLAunicodeString</dataType><updateType>Conditional</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Name of the tracked target.</semantics></attribute>
        <attribute><name>Position</name><dataType>Vec3Float64BE</dataType><updateType>Periodic</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Estimated target position in meters.</semantics></attribute>
        <attribute><name>Range</name><dataType>HLAfloat64BE</dataType><updateType>Periodic</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Slant range in meters.</semantics></attribute>
        <attribute><name>Bearing</name><dataType>HLAfloat64BE</dataType><updateType>Periodic</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Bearing in radians.</semantics></attribute>
        <attribute><name>RCS</name><dataType>HLAfloat64BE</dataType><updateType>Conditional</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Radar cross section used for this track.</semantics></attribute>
        <attribute><name>Time</name><dataType>HLAfloat64BE</dataType><updateType>Periodic</updateType><ownership>NoTransfer</ownership><sharing>PublishSubscribe</sharing><transportation>HLAreliable</transportation><order>Receive</order><semantics>Track time in seconds.</semantics></attribute>
      </objectClass>
    </objectClass>
  </objects>
  <interactions>
    <interactionClass>
      <name>HLAinteractionRoot</name>
      <interactionClass>
        <name>TrackReport</name>
        <sharing>PublishSubscribe</sharing>
        <transportation>HLAreliable</transportation>
        <order>Receive</order>
        <semantics>Radar-produced track report interaction.</semantics>
        <parameter><name>TrackId</name><dataType>HLAunicodeString</dataType><semantics>Track identifier.</semantics></parameter>
        <parameter><name>TargetName</name><dataType>HLAunicodeString</dataType><semantics>Tracked target name.</semantics></parameter>
        <parameter><name>Position</name><dataType>Vec3Float64BE</dataType><semantics>Estimated target position in meters.</semantics></parameter>
        <parameter><name>Range</name><dataType>HLAfloat64BE</dataType><semantics>Slant range in meters.</semantics></parameter>
        <parameter><name>Bearing</name><dataType>HLAfloat64BE</dataType><semantics>Bearing in radians.</semantics></parameter>
        <parameter><name>RCS</name><dataType>HLAfloat64BE</dataType><semantics>Radar cross section in square meters.</semantics></parameter>
        <parameter><name>Time</name><dataType>HLAfloat64BE</dataType><semantics>Track time in seconds.</semantics></parameter>
      </interactionClass>
    </interactionClass>
  </interactions>
  <time>
    <timeStamp><dataType>HLAfloat64BE</dataType><semantics>Scenario time in seconds.</semantics></timeStamp>
    <lookahead><dataType>HLAfloat64BE</dataType><semantics>Scenario lookahead in seconds.</semantics></lookahead>
  </time>
  <tags>
    <updateReflectTag><dataType>HLAunicodeString</dataType><semantics>Update tag.</semantics></updateReflectTag>
    <sendReceiveTag><dataType>HLAunicodeString</dataType><semantics>Interaction tag.</semantics></sendReceiveTag>
  </tags>
  <transportations>
    <transportation><name>HLAreliable</name><reliable>Yes</reliable><semantics>Reliable delivery.</semantics></transportation>
  </transportations>
  <dataTypes>
    <fixedRecordDataTypes>
      <fixedRecordData>
        <name>Vec3Float64BE</name>
        <encoding>HLAfixedRecord</encoding>
        <semantics>Three HLAfloat64BE values: x, y, z.</semantics>
        <field><name>x</name><dataType>HLAfloat64BE</dataType><semantics>X component.</semantics></field>
        <field><name>y</name><dataType>HLAfloat64BE</dataType><semantics>Y component.</semantics></field>
        <field><name>z</name><dataType>HLAfloat64BE</dataType><semantics>Z component.</semantics></field>
      </fixedRecordData>
    </fixedRecordDataTypes>
  </dataTypes>
</objectModel>
