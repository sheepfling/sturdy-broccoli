{
  "cases": [
    {
      "id": "readme_compliance",
      "path": "README.md",
      "must_contain": [
        "./tools/compliance generate",
        "./tools/compliance discover --show-backlog"
      ],
      "must_not_contain": [
        "python3 scripts/generate_compliance_artifacts.py",
        "python3 scripts/discover_backend_compliance.py --show-backlog"
      ]
    },
    {
      "id": "backend_compliance_discovery",
      "path": "docs/backend_compliance_discovery.md",
      "must_contain": [
        "./tools/compliance generate",
        "./tools/compliance discover --show-backlog",
        "analysis/compliance/certi_requirement_disposition.md",
        "analysis/compliance/certi-native_requirement_disposition.md",
        "analysis/compliance/certi-jpype_requirement_disposition.md",
        "analysis/compliance/certi-py4j_requirement_disposition.md",
        "analysis/compliance/portico_requirement_disposition.md",
        "analysis/compliance/pitch_requirement_disposition.md"
      ],
      "must_not_contain": [
        "python3 scripts/generate_compliance_artifacts.py",
        "python3 scripts/discover_backend_compliance.py"
      ]
    },
    {
      "id": "two_federate_quickstart",
      "path": "docs/two_federate_quickstart.md",
      "must_contain": [
        "./tools/two-federate",
        "./tools/rti-factories show in-memory --probe"
      ],
      "must_not_contain": [
        "python3 scripts/run_two_federate_suite.py",
        "../scripts/run_two_federate_suite.py"
      ]
    },
    {
      "id": "vendor_parity_artifacts",
      "path": "docs/vendor_parity_artifacts.md",
      "must_contain": [
        "./tools/vendor-parity",
        "./tools/vendor-edge all"
      ],
      "must_not_contain": [
        "python3 scripts/run_vendor_parity_artifacts.py",
        "./scripts/ci/vendor_edge_matrix.sh all"
      ]
    },
    {
      "id": "package_dependency_tree",
      "path": "docs/package_dependency_tree.md",
      "must_contain": [
        "./tools/package-deps generate"
      ],
      "must_not_contain": [
        "python3 scripts/generate_package_dependency_tree.py"
      ]
    },
    {
      "id": "rti_options_and_test_matrix",
      "path": "docs/rti_options_and_test_matrix.md",
      "must_contain": [
        "./tools/rti-options generate"
      ],
      "must_not_contain": [
        "python3 scripts/update_rti_options_matrix.py"
      ]
    },
    {
      "id": "local_verification_commands",
      "path": "docs/local_verification_commands.md",
      "must_contain": [
        "./tools/lint",
        "./tools/test-surface recommend",
        "./tools/python verify-fast"
      ],
      "must_not_contain": [
        "./scripts/ci/lint.sh"
      ]
    }
  ],
  "multi_path_cases": [
    {
      "id": "local_pytest_flow",
      "paths": [
        "README.md",
        "docs/python_environment.md",
        "tests/README.md"
      ],
      "must_contain": [
        "./tools/test"
      ]
    }
  ]
}
